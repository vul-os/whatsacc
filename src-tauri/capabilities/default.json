{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window: core APIs plus CORS-free HTTP to any user-chosen gateway (http for LAN/dev gateways, https for the internet).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" },
        { "url": "http://**:*" },
        { "url": "https://**:*" }
      ]
    }
  ]
}
