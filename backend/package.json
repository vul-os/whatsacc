{
  "name": "whatsacc-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:dev": "wrangler dev --env=dev",
    "dev:main": "wrangler dev --env=main",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env=dev",
    "deploy:main": "wrangler deploy --env=main",
    "secrets:dev": "node scripts/push-secrets.mjs dev",
    "secrets:main": "node scripts/push-secrets.mjs main",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/lib",
    "test:integration": "node --env-file=../.env ./node_modules/vitest/vitest.mjs run tests/integration",
    "test:security": "node --env-file=../.env ./node_modules/vitest/vitest.mjs run tests/security",
    "test:contract": "vitest run tests/contract",
    "test:contract:paystack": "vitest run tests/contract/paystack.test.ts",
    "test:contract:resend": "vitest run tests/contract/resend.test.ts",
    "migrate": "node --env-file=../.env scripts/migrate.mjs",
    "migrate:dev": "node --env-file=../.env.dev scripts/migrate.mjs",
    "migrate:main": "node --env-file=../.env.main scripts/migrate.mjs",
    "seed:user": "node --env-file=../.env scripts/seed-user.mjs",
    "seed:demo": "node --env-file=../.env scripts/seed-demo-data.mjs",
    "payouts": "node --env-file=../.env scripts/run-monthly-payouts.mjs",
    "payouts:dev": "node --env-file=../.env.dev scripts/run-monthly-payouts.mjs",
    "test:billing": "node --env-file=../.env scripts/test-billing.mjs",
    "test:billing:dev": "node --env-file=../.env.dev scripts/test-billing.mjs"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.2",
    "@neondatabase/serverless": "^0.10.4",
    "@noble/hashes": "^2.2.0",
    "hash-wasm": "^4.12.0",
    "hono": "^4.6.0",
    "jose": "^5.9.6",
    "pdf-lib": "^1.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20250521.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0",
    "postgres": "^3.4.9",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.85.0",
    "ws": "^8.20.0"
  }
}
