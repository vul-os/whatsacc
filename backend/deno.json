{
  "name": "@whatsacc/backend",
  "version": "0.0.0",
  "tasks": {
    "dev": "deno run -A --watch --env-file=../.env cmd/server/main.ts",
    "dev:dev": "deno run -A --watch --env-file=../.env.dev cmd/server/main.ts",
    "dev:main": "deno run -A --watch --env-file=../.env.main cmd/server/main.ts",
    "start": "deno run -A cmd/server/main.ts",
    "migrate": "deno run -A --env-file=../.env cmd/migrate/main.ts",
    "migrate:dev": "deno run -A --env-file=../.env.dev cmd/migrate/main.ts",
    "migrate:main": "deno run -A --env-file=../.env.main cmd/migrate/main.ts",
    "test": "deno test -A",
    "check": "deno check cmd/ src/"
  },
  "imports": {
    "@/": "./src/",
    "hono": "npm:hono@^4.6.0",
    "hono/cors": "npm:hono@^4.6.0/cors",
    "hono/logger": "npm:hono@^4.6.0/logger",
    "hono/cookie": "npm:hono@^4.6.0/cookie",
    "hono/utils/http-status": "npm:hono@^4.6.0/utils/http-status",
    "@hono/zod-validator": "npm:@hono/zod-validator@^0.4.2",
    "postgres": "npm:postgres@^3.4.4",
    "jose": "npm:jose@^5.9.6",
    "hash-wasm": "npm:hash-wasm@^4.11.0",
    "zod": "npm:zod@^3.23.8",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": true,
    "semiColons": true
  }
}
