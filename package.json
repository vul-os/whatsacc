{
  "name": "lintel",
  "private": true,
  "version": "0.0.0",
  "description": "Texts that open gates — decentralized chat-driven physical access control (portal app + static site/)",
  "license": "MIT",
  "author": "imranparuk",
  "repository": {
    "type": "git",
    "url": "https://github.com/vul-os/lintel"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode dev",
    "build:main": "tsc -b && vite build --mode main",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "screenshotter": "node scripts/screenshotter.mjs",
    "tauri": "tauri",
    "app:dev": "tauri dev",
    "app:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-http": "^2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "playwright": "^1.57.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.0",
    "vite": "^8.0.10",
    "vitest": "^3.2.7"
  }
}
