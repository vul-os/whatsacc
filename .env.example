# lintel — local development env (repo root)
#
# Copy to .env:   cp .env.example .env
#
# Who reads this file:
#   - backend node scripts (migrate, seeds, test:integration, test:security)
#     via `node --env-file=../.env` — see backend/package.json
#   - Vite (frontend): only VITE_-prefixed vars are exposed to the browser
#   - NOT wrangler: `wrangler dev` reads backend/.dev.vars instead — see
#     backend/.dev.vars.example
#
# Authoritative var list + semantics: backend/src/lib/env.ts

# ── Required ─────────────────────────────────────────────────────────────

# Postgres connection string (local Postgres 16+, or a Neon branch).
# Local Postgres usually has no TLS — keep ?sslmode=disable.
# Integration tests TRUNCATE tables: point at a throwaway database.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lintel?sslmode=disable

# HS256 secret for access/refresh tokens. Required — the backend refuses to
# boot without it. Any long random string for local dev.
JWT_SECRET=dev-only-change-me

# ── Core (defaults are fine locally) ─────────────────────────────────────

# 'local' | 'dev' | 'main' | 'test' (test skips real Resend sends)
APP_ENV=local

# Frontend base URL — used in email links + post-OAuth redirect
APP_PUBLIC_URL=http://localhost:5173

# ── Google OAuth sign-in (optional; empty disables Google login) ─────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# ── Resend transactional email (optional; unset = emails logged, not sent) ─

RESEND_API_KEY=

# ── Meta WhatsApp Cloud API channel (optional) ───────────────────────────

# App secret — verifies X-Hub-Signature-256 on inbound webhooks
WHATSAPP_APP_SECRET=
# Token you choose; echoed by Meta's webhook verification handshake
WHATSAPP_VERIFY_TOKEN=
# Bearer token for sending replies via the Graph API
WHATSAPP_ACCESS_TOKEN=
# The WABA phone number id replies are sent from
WHATSAPP_PHONE_NUMBER_ID=
# Graph API version (default v21.0)
#WHATSAPP_GRAPH_VERSION=v21.0

# ── Telegram bot channel (optional) ──────────────────────────────────────

TELEGRAM_BOT_TOKEN=
# Secret token set on the webhook; verifies X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=

# ── Slack channel (optional) ─────────────────────────────────────────────

SLACK_BOT_TOKEN=
# Verifies Slack request signatures (X-Slack-Signature)
SLACK_SIGNING_SECRET=
SLACK_APP_ID=

# ── Abuse-protection rate limits (optional; see backend/src/lib/rate-limit.ts)
# Non-negative integers; unset = production defaults 10 / 30 / 10 / 500.

# Seconds between opens per member per access point (default 10)
#RATE_OPEN_COOLDOWN_S=10
# Opens per member per hour (default 30)
#RATE_OPENS_PER_HOUR=30
# Chat messages per sender per minute (default 10)
#RATE_CHAT_MSGS_PER_MIN=10
# Opens per account (all members) per hour (default 500)
#RATE_ACCOUNT_OPENS_PER_HOUR=500

# ── Instance-admin bootstrap (optional) ──────────────────────────────────

# One-time claim token: redeemable exactly once via POST /admin/claim while
# no platform admin exists yet. Useless after the instance is claimed.
#ADMIN_CLAIM_TOKEN=

# ── Frontend (Vite; VITE_-prefixed vars are PUBLIC in the browser bundle) ─

# API base URL the portal talks to (default http://localhost:8787)
#VITE_API_BASE_URL=http://localhost:8787
# Mapbox token for the location address autocomplete (optional; the input
# degrades to plain text without it)
#VITE_MAPBOX_TOKEN=
